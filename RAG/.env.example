# ─── Ollama (shared model server) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# ─── RAG pipeline ────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=/data/faiss_index
DOCS_PATH=/data/documents
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=4

# ─── RAG API security ─────────────────────────────────────────────────────────
# Set a strong secret before deploying. Leave blank to disable auth (dev only).
RAG_API_KEY=change-me-before-deploy

# ─── Semantic Cache client ────────────────────────────────────────────────────
# URL of the running semcache-api container (or localhost for local dev)
SEMCACHE_BASE_URL=http://semcache-api:8000

# Must match the API_KEY configured in the SemanticCaching service
SEMCACHE_API_KEY=change-me-before-deploy

# Agent namespace — groups RAG cache entries separately from other agents
SEMCACHE_AGENT_ID=rag-workflow

# How long RAG answers stay in the semantic cache (seconds)
SEMCACHE_TTL=3600

# Timeout for cache HTTP calls (seconds) — keeps RAG latency bounded if cache is slow
SEMCACHE_TIMEOUT=5.0
