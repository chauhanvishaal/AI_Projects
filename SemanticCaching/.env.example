# .env.example — copy to .env and fill in values before running
# -------------------------------------------------------------
# cp .env.example .env

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
# URL of the Redis server. In docker-compose this resolves to the
# "redis" service; for local dev use redis://localhost:6379
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------
# Ollama (local LLM)
# ------------------------------------------------------------------
# Base URL of the Ollama server.
OLLAMA_BASE_URL=http://ollama:11434

# Which Ollama model to use (must be pulled first by ollama-init).
OLLAMA_MODEL=llama3

# ------------------------------------------------------------------
# Semantic cache settings
# ------------------------------------------------------------------
# Ollama embedding model name (pulled into Ollama by ollama-init on first start).
# nomic-embed-text is free, local, and produces 768-dim vectors.
EMBEDDING_MODEL=nomic-embed-text

# Cosine similarity threshold for a cache hit (0.0–1.0).
# Higher = stricter matching, fewer false positives.
SIMILARITY_THRESHOLD=0.92

# Default TTL in seconds for cached entries (3600 = 1 hour).
DEFAULT_TTL=3600

# Namespace prefix for Redis keys — use different values per environment
# (e.g. "dev", "staging", "prod") to isolate caches.
NAMESPACE=default

# ------------------------------------------------------------------
# Distributed lock settings
# ------------------------------------------------------------------
# How long (seconds) to hold the lock before it auto-expires.
LOCK_TIMEOUT=30

# How many times to retry acquiring the lock before giving up.
MAX_LOCK_RETRIES=10

# ------------------------------------------------------------------
# API authentication
# ------------------------------------------------------------------
# Shared secret required in the X-API-Key header for all protected routes.
# Generate a strong random value: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable authentication (NOT recommended for production).
API_KEY=change-me-before-deploy

# ------------------------------------------------------------------
# Example demo mode (example_usage.py only)
# ------------------------------------------------------------------
# Set to "langchain", "http", or "both"
DEMO_MODE=both

# Base URL used by example_usage.py for the HTTP API mode.
API_BASE_URL=http://localhost:8000

# ------------------------------------------------------------------
# Note: sentence-transformers and torch are no longer required.
# Embeddings are served by Ollama (OLLAMA_BASE_URL above).
# ------------------------------------------------------------------
